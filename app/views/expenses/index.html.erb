<div class="dashboard-page dashboard-page--expenses">
  <header class="dashboard-header d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <div>
      <h1 class="dashboard-title text-success fw-bolder">Despesas</h1>
      <p class="dashboard-subtitle text-muted mb-0">Controle suas saídas mensais</p>
    </div>
    <div class="d-flex gap-2 align-items-center flex-wrap">
      <%= form_with url: expenses_path, method: :get, local: true, class: "period-filter" do %>
        <span class="period-filter-icon">
          <i class="fa-regular fa-calendar"></i>
        </span>
        <div class="period-filter-selects">
          <%= select_tag :month, options_for_select(@months, @selected_month), class: "form-select form-select-sm period-select period-select-month" %>
          <%= select_tag :year, options_for_select(@years, @selected_year), class: "form-select form-select-sm period-select period-select-year" %>
        </div>
        <%= button_tag type: "submit", class: "btn button-green btn-sm period-filter-btn px-3" do %>
          <i class="fa-solid fa-filter me-1"></i> Filtrar
        <% end %>
      <% end %>
      <% if @is_filtered %>
        <%= link_to expenses_path, class: "btn btn-outline-secondary btn-sm px-3" do %>
          <i class="fa-solid fa-list me-1"></i> Ver Todos
        <% end %>
      <% end %>
    </div>
  </header>
  <div class="d-flex gap-2 mb-4">
    <!-- Button trigger modal -->
    <button type="button" class="btn btn-custom-action" data-bs-toggle="modal" data-bs-target="#exampleModal">
      <i class="bi bi-plus-circle"></i> Novo gasto
    </button>

    <!-- Modal -->
    <div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h1 class="modal-title fs-5" id="exampleModalLabel">Novo Gasto</h1>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <%= render "form" %>
      </div>
      <!-- <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
        <button type="button" class="btn btn-primary">Save changes</button>
      </div> -->
    </div>
    </div>
    </div>

</div>

  <% if @expenses.any? %>
    <% @expenses_by_month.each do |month, expenses| %>
      <% total = expenses.sum(&:value) %>
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden mb-4">
        <div class="card-header bg-transparent d-flex flex-wrap justify-content-between align-items-center gap-2 py-3">
          <h2 class="h5 mb-0 fw-bold"><%= l(month, format: :month_year) %></h2>
          <span class="badge bg-success bg-opacity-10 text-success fs-6 fw-bold border-0"><%= number_to_currency(total, unit: "R$ ", separator: ",", delimiter: ".") %></span>
        </div>
        <div class="list-cards-wrapper">
          <% expenses.each do |expense| %>
            <div class="list-item-card d-flex align-items-center justify-content-between gap-3 flex-wrap flex-md-nowrap">
              <div class="d-flex align-items-center gap-3 overflow-hidden" style="min-width: 0;">
                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0 bg-danger bg-opacity-10 text-danger" style="width: 46px; height: 46px;">
                  <i class="fa-solid fa-receipt fs-5"></i>
                </div>
                <div class="d-flex flex-column text-truncate">
                  <span class="fw-bold text-truncate" style="font-size: 1rem; color: var(--theme-text);"><%= expense.description.presence || expense.expense_type.presence || "Despesa" %></span>
                  <div class="d-flex align-items-center gap-2 small text-muted mt-1">
                    <span class="text-truncate" style="max-width: 120px;"><%= expense.expense_type.presence || "Sem categoria" %></span>
                    <i class="fa-solid fa-circle" style="font-size: 3px; opacity: 0.5;"></i>
                    <span class="text-nowrap"><%= expense.date.strftime("%d %b") %></span>
                  </div>
                </div>
              </div>

              <div class="d-flex align-items-center gap-3 flex-shrink-0 ms-auto">
                <span class="fw-bold text-danger fs-6 text-nowrap"><%= number_to_currency(expense.value, unit: "R$ ") %></span>

                <div class="d-none d-md-flex gap-1">
                  <%= link_to edit_expense_path(expense), class: "btn btn-sm btn-outline-secondary border-0 rounded-circle", style: "width: 38px; height: 38px; display: flex; align-items: center; justify-content: center;", title: "Editar" do %>
                    <i class="fa-solid fa-pen"></i>
                  <% end %>
                  <%= link_to expense_path(expense), class: "btn btn-sm btn-outline-danger border-0 rounded-circle", style: "width: 38px; height: 38px; display: flex; align-items: center; justify-content: center;", title: "Excluir",
                      data: { turbo_method: :delete, turbo_confirm: "Tem certeza que deseja excluir?" } do %>
                    <i class="fa-solid fa-trash"></i>
                  <% end %>
                </div>

                <div class="dropdown d-md-none">
                  <button class="btn btn-sm btn-link text-muted px-2 border-0" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="fa-solid fa-ellipsis-vertical"></i>
                  </button>
                  <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 rounded-4" style="background-color: var(--theme-bg-card);">
                    <li>
                      <%= link_to edit_expense_path(expense), class: "dropdown-item d-flex align-items-center gap-2 py-2" do %>
                        <i class="fa-solid fa-pen text-muted"></i> Editar
                      <% end %>
                    </li>
                    <li>
                      <%= link_to expense_path(expense), class: "dropdown-item d-flex align-items-center gap-2 py-2 text-danger", data: { turbo_method: :delete, turbo_confirm: "Tem certeza que deseja excluir?" } do %>
                        <i class="fa-solid fa-trash"></i> Excluir
                      <% end %>
                    </li>
                  </ul>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="card border-0 rounded-4 shadow-sm">
      <div class="card-body text-center py-5">
        <div class="text-muted mb-3">
          <i class="fa-solid fa-wallet fa-3x"></i>
        </div>
        <p class="text-muted mb-3">Nenhum gasto cadastrado.</p>
        <%= link_to "Cadastrar primeiro gasto", new_expense_path, class: "btn btn-primary" %>
      </div>
    </div>
  <% end %>
</div>
