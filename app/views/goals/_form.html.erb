<%= simple_form_for(@goal) do |f| %>
  <%= f.input :description, label: "Descrição", input_html: { placeholder: "Ex: Economizar para viagem" } %>
  <%= f.input :goal_type, as: :select, label: "Tipo de meta",
      collection: Goal::TYPES.map { |k, v| [v, k] },
      include_blank: "Selecione o tipo" %>
  <%= f.input :target_value, label: "Valor alvo (R$)", input_html: { step: "0.01", min: "0" } %>
  
  <div id="goal-category-wrapper" style="<%= @goal.goal_type == 'savings' ? 'display: none;' : '' %>">
    <datalist id="expense-categories-datalist">
      <option value="Total">
      <% Expense::CATEGORIES.each do |cat| %>
        <option value="<%= cat %>">
      <% end %>
    </datalist>
    <datalist id="investment-categories-datalist">
      <option value="Total">
      <% current_user.investments.select(:investment_type).distinct.pluck(:investment_type).compact.reject(&:blank?).uniq.sort.each do |cat| %>
        <option value="<%= cat %>">
      <% end %>
    </datalist>
    <%= f.input :category, label: "Categoria alvo (Opcional)", hint: "Deixe 'Total' para meta global ou digite uma Categoria.", hint_html: { style: "color: var(--theme-text-muted) !important; font-size: 0.8rem; opacity: 0.85;" }, input_html: { list: @goal.goal_type == 'investment' ? "investment-categories-datalist" : "expense-categories-datalist", placeholder: "Total" } %>
  </div>

  <div class="row">
    <div class="col-sm-6">
      <%= f.input :month, as: :select, label: "Mês",
          collection: (1..12).map { |m| [l(Date.new(2000, m, 1), format: :month_year).split(' ').first, m] } %>
    </div>
    <div class="col-sm-6">
      <%= f.input :year, label: "Ano", input_html: { min: 2020, max: 2100 } %>
    </div>
  </div>
  <div class="d-flex flex-wrap gap-2 mt-3">
    <%= f.button :submit, @goal.persisted? ? "Atualizar meta" : "Criar meta", class: "btn-primary" %>
    <%= link_to "Cancelar", goals_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>

<script>
  document.addEventListener('turbo:load', function() {
    setupGoalTypeToggle();
  });
  
  setupGoalTypeToggle();

  function setupGoalTypeToggle() {
    const typeSelect = document.getElementById('goal_goal_type');
    const categoryWrapper = document.getElementById('goal-category-wrapper');
    const categoryInput = document.getElementById('goal_category');
    
    function applyCategoryLogic(val) {
      if (val === 'savings') {
        categoryWrapper.style.display = 'none';
        if (categoryInput) categoryInput.value = '';
      } else {
        categoryWrapper.style.display = 'block';
        if (categoryInput) {
          if (val === 'expense') {
            categoryInput.setAttribute('list', 'expense-categories-datalist');
          } else if (val === 'investment') {
            categoryInput.setAttribute('list', 'investment-categories-datalist');
          }
        }
      }
    }

    if (typeSelect && categoryWrapper) {
      typeSelect.addEventListener('change', function(e) {
        applyCategoryLogic(e.target.value);
      });
      // trigger on load
      applyCategoryLogic(typeSelect.value);
    }
  }
</script>
