<%= simple_form_for(@goal, html: { data: { controller: "goal-form" } }) do |f| %>
  <%= f.input :description, label: "Descrição", input_html: { placeholder: "Ex: Economizar para viagem" } %>
  <%= f.input :goal_type, as: :select, label: "Tipo de meta",
      collection: Goal::TYPES.map { |k, v| [v, k] },
      include_blank: "Selecione o tipo",
      input_html: { data: { goal_form_target: "typeSelect", action: "change->goal-form#onTypeChange" } } %>
  <%= f.input :target_value, label: "Valor alvo (R$)", input_html: { step: "0.01", min: "0" } %>

  <div data-goal-form-target="categoryWrapper" class="<%= 'd-none' if @goal.goal_type == 'savings' %>">
    <datalist id="expense-categories-datalist">
      <option value="Total">
      <% current_user.expenses.select(:expense_type).distinct.pluck(:expense_type).compact.reject(&:blank?).uniq.sort.each do |cat| %>
        <option value="<%= cat %>">
      <% end %>
    </datalist>
    <datalist id="investment-categories-datalist">
      <option value="Total">
      <% current_user.investments.select(:investment_type).distinct.pluck(:investment_type).compact.reject(&:blank?).uniq.sort.each do |cat| %>
        <option value="<%= cat %>">
      <% end %>
    </datalist>
    <%= f.input :category, label: "Categoria alvo (Opcional)", hint: "Deixe 'Total' para meta global ou digite uma Categoria.", hint_html: { class: "goal-form-hint" }, input_html: { list: @goal.goal_type == 'investment' ? "investment-categories-datalist" : "expense-categories-datalist", placeholder: "Total", data: { goal_form_target: "categoryInput" } } %>
  </div>

  <div class="row">
    <div class="col-sm-6">
      <%= f.input :month, as: :select, label: "Mês",
          collection: (1..12).map { |m| [l(Date.new(2000, m, 1), format: :month_year).split(' ').first, m] } %>
    </div>
    <div class="col-sm-6">
      <%= f.input :year, label: "Ano", input_html: { min: 2020, max: 2100 } %>
    </div>
  </div>
  <div class="d-flex flex-wrap gap-2 mt-3">
    <%= f.button :submit, @goal.persisted? ? "Atualizar meta" : "Criar meta", class: "btn-primary" %>
    <%= link_to "Cancelar", goals_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
