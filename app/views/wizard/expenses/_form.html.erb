<turbo-frame id="message_<%= message.id %>_wizard">
  <div class="card shadow-sm border-0 mt-2" style="border-radius: 12px; background-color: var(--theme-bg-main); width: 280px;">
    <div class="card-body p-3">
      <h6 class="card-title text-center mb-3" style="color: var(--theme-danger);">
        <i class="fa-solid fa-arrow-down me-1"></i> Nova Despesa
      </h6>
      <%= simple_form_for expense, url: chat_wizard_expenses_path(chat, message_id: message.id), html: { class: "mb-0" } do |f| %>
        <%= f.input :date, as: :string, label: false, input_html: { type: "date", class: "form-control form-control-sm wizard-input mb-2", value: Date.today } %>
        <%= f.input :value, label: false, placeholder: "Valor (R$)", input_html: { step: "0.01", min: "0", class: "form-control form-control-sm wizard-input mb-2" } %>
        <%= f.input :description, label: false, placeholder: "Descrição", input_html: { class: "form-control form-control-sm wizard-input mb-2" } %>
        <%= f.input :expense_type, label: false, placeholder: "Categoria", input_html: { class: "form-control form-control-sm wizard-input mb-3" } %>
        
        <div class="d-flex justify-content-between">
          <%= link_to "Cancelar", chat_wizard_expense_path(chat, message.id), data: { turbo_method: :delete }, class: "btn btn-sm wizard-btn-cancel w-100 me-2" %>
          <%= f.button :submit, "Salvar", class: "btn btn-sm w-100", style: "background-color: var(--theme-danger); color: white; border: none;" %>
        </div>
      <% end %>
    </div>
  </div>
</turbo-frame>
