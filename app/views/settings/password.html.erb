<div class="settings-section-page">
  <header class="mb-4">
    <h1 class="settings-section-title">Senha</h1>
    <p class="text-muted">Atualizar senha</p>
  </header>

  <div class="card border-0 rounded-4 shadow-sm p-4">
    <%= simple_form_for(current_user, url: update_settings_password_path, method: :patch) do |f| %>
      <%= f.input :current_password,
                  label: "Senha atual",
                  required: true,
                  input_html: { autocomplete: "current-password" } %>
      <%= f.input :password,
                  label: "Nova senha",
                  required: true,
                  input_html: { autocomplete: "new-password" } %>
      <%= f.input :password_confirmation,
                  label: "Nova senha",
                  required: true,
                  input_html: { autocomplete: "new-password" } %>
      <div class="text-center mt-3">
        <%= f.button :submit, "Atualizar", class: "btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>
