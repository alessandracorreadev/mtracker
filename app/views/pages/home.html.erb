  <div class="container d-flex flex-wrap justify-content-between align-items-center">
    <small class="text-secondary">© 2025 MTracker. All rights reserved.</small>
    <div class="d-flex gap-3">
      <a href="#" class="text-secondary">Privacy Policy</a>
      <a href="#" class="text-secondary">Terms of Use</a>
      <a href="#" class="text-secondary">Contact Us</a>
    </div>
    <div class="d-flex gap-3 mt-2 mt-md-0">
      <a href="#" class="text-white"><i class="fa-brands fa-linkedin"></i></a>
      <a href="#" class="text-white"><i class="fa-brands fa-youtube"></i></a>
      <a href="#" class="text-white"><i class="fa-brands fa-facebook"></i></a>
      <a href="#" class="text-white"><i class="fa-brands fa-twitter"></i></a>
    </div>
  </div>
</footer>
