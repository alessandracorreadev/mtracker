<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6 text-center">
      <h1 class="mb-4">Money Tracker</h1>
      <p class="text-muted mb-4">
        Controle seus gastos, ganhos e investimentos em um só lugar.
      </p>

      <% if user_signed_in? %>
        <%= link_to "Ir para o Dashboard", dashboard_path,
                    class: "btn btn-primary btn-lg px-4 me-2",
                    data: { turbo: false } %>
      <% else %>
        <div class="d-flex flex-column flex-sm-row justify-content-center gap-2">
          <%= link_to "Entrar", new_user_session_path,
                      class: "btn btn-primary btn-lg px-4",
                      data: { turbo: false } %>
          <%= link_to "Criar conta", new_user_registration_path,
                      class: "btn btn-outline-primary btn-lg px-4",
                      data: { turbo: false } %>
        </div>
      <% end %>
    </div>
  </div>
</div>
