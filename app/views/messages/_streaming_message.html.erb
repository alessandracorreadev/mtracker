<div id="stream_<%= stream_id %>">
  <div class="d-flex w-100 justify-content-start">
    <div class="chat-bubble assistant" style="min-width: 70px;">
      <% if content.present? %>
        <div style="white-space: pre-wrap;"><%= content %></div>
      <% else %>
        <div class="typing-indicator">
          <span></span><span></span><span></span>
        </div>
      <% end %>

      <% if local_assigns[:final] %>
        <!-- Mark as final for frontend if needed -->
      <% end %>
    </div>
  </div>
</div>
