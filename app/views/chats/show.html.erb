<%= turbo_frame_tag "chat_widget_frame" do %>
  <div class="d-flex flex-column chat-wrapper" data-controller="chat">
    <%= turbo_stream_from @chat %>

    <!-- Premium Header -->
    <div class="premium-chat-header d-flex justify-content-between align-items-center flex-shrink-0 z-1">
      <div class="d-flex align-items-center">
        <div class="bg-white rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm chat-header-icon">
          <i class="fa-solid fa-bolt" style="color: var(--theme-accent); font-size: 1.1rem;"></i>
        </div>
        <div>
          <h6 class="mb-0 fw-bold chat-header-title">Mtracker AI</h6>
          <div class="d-flex align-items-center chat-header-status">
            <div class="chat-status-dot"></div>
            Online e Pronto
          </div>
        </div>
      </div>
      <div class="d-flex align-items-center gap-2">
        <button type="button" class="btn-close btn-close-white" data-close-chat aria-label="Fechar chat"></button>
      </div>
    </div>

    <!-- Messages Area -->
    <div class="chat-container flex-grow-1 p-3 premium-scroll chat-messages-area" id="messages-container" data-chat-target="container">
      <% if @chat.messages.none? %>
        <div class="text-center mt-auto mb-auto" style="color: var(--theme-text-muted);">
          <div class="rounded-circle p-4 mb-3 d-inline-block chat-empty-icon">
            <i class="fa-solid fa-coins fa-2x" style="color: var(--theme-accent);"></i>
          </div>
          <p class="fw-bold mb-1 chat-empty-title">Como posso ajudar?</p>
          <p class="chat-empty-subtitle">Tire dúvidas sobre suas finanças, investimentos ou peça dicas de organização financeira.</p>
        </div>
      <% end %>

      <div id="messages" data-chat-target="messages">
        <%= render "messages/messages", messages: @chat.messages.order(:created_at) %>
      </div>
    </div>

    <!-- Premium Form Area -->
    <div class="chat-input-wrapper flex-shrink-0">
      <div id="chat_form_container">
        <%= render "messages/form", chat: @chat, message: Message.new %>
      </div>
    </div>
  </div>
<% end %>
