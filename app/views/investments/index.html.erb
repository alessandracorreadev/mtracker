<div class="dashboard-page">
  <header class="dashboard-header d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <div>
      <h1 class="dashboard-title">Investimentos</h1>
      <p class="dashboard-subtitle text-muted mb-0">Lista de investimentos por mês</p>
    </div>
    <%= link_to new_investment_path, class: "btn btn-primary" do %>
      <i class="fa-solid fa-plus me-1"></i> Novo investimento
    <% end %>
  </header>

  <% if @investments.any? %>
    <% @investments_by_month.each do |month, investments| %>
      <% total = investments.sum(&:value) %>
      <div class="card rounded-3 shadow-sm overflow-hidden mb-4">
        <div class="card-header bg-transparent d-flex flex-wrap justify-content-between align-items-center gap-2 py-3">
          <h2 class="h5 mb-0 fw-bold"><%= l(month, format: :month_year) %></h2>
          <span class="badge bg-secondary fs-6"><%= number_to_currency(total, unit: "R$ ", separator: ",", delimiter: ".") %></span>
        </div>
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Data</th>
                <th>Descrição</th>
                <th>Categoria</th>
                <th class="text-end">Valor</th>
                <th class="text-end" style="width: 140px;">Ações</th>
              </tr>
            </thead>
            <tbody>
              <% investments.each do |investment| %>
                <tr>
                  <td><%= investment.date.strftime("%d/%m/%Y") %></td>
                  <td><%= investment.description.presence || "—" %></td>
                  <td><%= investment.investment_type.presence || "—" %></td>
                  <td class="text-end fw-semibold"><%= number_to_currency(investment.value, unit: "R$ ", separator: ",", delimiter: ".") %></td>
                  <td class="text-end">
                    <%= link_to edit_investment_path(investment), class: "btn btn-sm btn-outline-secondary", title: "Editar" do %>
                      <i class="fa-solid fa-pen"></i>
                    <% end %>
                    <%= link_to investment_path(investment), class: "btn btn-sm btn-outline-danger", title: "Excluir",
                        data: { turbo_method: :delete, turbo_confirm: "Tem certeza que deseja excluir este investimento?" } do %>
                      <i class="fa-solid fa-trash"></i>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="card rounded-3 shadow-sm">
      <div class="card-body text-center py-5">
        <div class="text-muted mb-3">
          <i class="fa-solid fa-chart-line fa-3x"></i>
        </div>
        <p class="text-muted mb-3">Nenhum investimento cadastrado.</p>
        <%= link_to "Cadastrar primeiro investimento", new_investment_path, class: "btn btn-primary" %>
      </div>
    </div>
  <% end %>
</div>
