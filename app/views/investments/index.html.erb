<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Investimentos</h1>
    <%= link_to "Novo investimento", new_investment_path, class: "btn btn-primary" %>
  </div>

  <table class="table">
    <thead>
      <tr>
        <th>Data</th>
        <th>Descrição</th>
        <th>Categoria</th>
        <th>Valor (R$)</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @investments.each do |investment| %>
        <tr>
          <td><%= investment.date %></td>
          <td><%= investment.description %></td>
          <td><%= investment.investment_type %></td>
          <td><%= investment.value %></td>
          <td>
            <%= link_to "Editar", edit_investment_path(investment), class: "btn btn-sm btn-outline-secondary" %>
            <%= link_to "Excluir", investment_path(investment), class: "btn btn-sm btn-outline-danger",
                data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
