<div class="dashboard-page dashboard-page--investments">
  <!-- Dashboard-identical Header -->
  <header class="dashboard-header d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
      <h1 class="dashboard text-success fw-bolder">Meus Rendimentos</h1>
      <p class="dashboard-subtitle text-muted mb-0">Análise de performance por categoria</p>
    </div>
    <%= link_to investments_path, class: "btn btn-primary" do %>
      <i class="fa-solid fa-list me-1"></i> Ver aportes detalhados
    <% end %>
  </header>

  <!-- Standardized Hero Card (Patrimônio Total) -->
  <section class="mb-4">
    <div class="card border-0 rounded-4 shadow-sm position-relative overflow-hidden hero-saldo-container">
      <div class="card-body p-4 p-md-5">
        <div class="row align-items-center">
          <div class="col-md-7">
            <h6 class="text-uppercase text-muted small fw-bold mb-2" style="letter-spacing: 1px;">Patrimônio Total</h6>
            <h2 class="display-5 fw-bolder mb-0 text-info"><%= number_to_currency(@total_current_value, unit: "R$ ", separator: ",", delimiter: ".") %></h2>
          </div>
          <div class="col-md-5 text-md-end mt-4 mt-md-0">
            <div class="d-inline-flex align-items-center p-3 rounded-4 bg-info bg-opacity-10">
              <i class="fa-solid fa-wallet me-2 text-info fs-4"></i>
              <span class="text-info fw-bold h5 mb-0">Carteira Atual</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3-Card Summary Row -->
  <section class="dashboard-cards row g-3 mb-4">
    <div class="col-12 col-lg-4">
      <div class="card border-0 rounded-4 shadow-sm h-100">
        <div class="card-body d-flex align-items-center gap-3 p-4">
          <div class="dashboard-card-icon rounded-4 d-flex align-items-center justify-content-center bg-secondary bg-opacity-10 text-muted" style="width: 56px; height: 56px; flex-shrink: 0;">
            <i class="fa-solid fa-vault fs-4"></i>
          </div>
          <div>
            <h6 class="card-subtitle text-muted mb-1 small text-uppercase fw-bold" style="font-size: 0.65rem; letter-spacing: 0.5px;">Total Investido</h6>
            <p class="card-value mb-0 h4 fw-bold"><%= number_to_currency(@total_invested, unit: "R$ ", separator: ",", delimiter: ".") %></p>
          </div>
        </div>
      </div>
    </div>
    <div class="col-12 col-lg-4">
      <div class="card border-0 rounded-4 shadow-sm h-100">
        <div class="card-body d-flex align-items-center gap-3 p-4">
          <div class="dashboard-card-icon rounded-4 d-flex align-items-center justify-content-center icon-box-success" style="width: 56px; height: 56px; flex-shrink: 0;">
            <i class="fa-solid fa-arrow-trend-up fs-4"></i>
          </div>
          <div>
            <h6 class="card-subtitle text-muted mb-1 small text-uppercase fw-bold" style="font-size: 0.65rem; letter-spacing: 0.5px;">Lucro Acumulado</h6>
            <p class="card-value mb-0 h4 fw-bold text-success"><%= number_to_currency(@total_yield, unit: "R$ ", separator: ",", delimiter: ".") %></p>
          </div>
        </div>
      </div>
    </div>
    <div class="col-12 col-lg-4">
      <div class="card border-0 rounded-4 shadow-sm h-100">
        <div class="card-body d-flex align-items-center gap-3 p-4">
          <div class="dashboard-card-icon rounded-4 d-flex align-items-center justify-content-center bg-info bg-opacity-10 text-info" style="width: 56px; height: 56px; flex-shrink: 0;">
            <i class="fa-solid fa-calendar-check fs-4"></i>
          </div>
          <div>
            <h6 class="card-subtitle text-muted mb-1 small text-uppercase fw-bold" style="font-size: 0.65rem; letter-spacing: 0.5px;">Est. Mensal</h6>
            <p class="card-value mb-0 h4 fw-bold text-info"><%= number_to_currency(@monthly_estimated_yield, unit: "R$ ", separator: ",", delimiter: ".") %></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- New Indicators: Taxa de Poupança & Rentabilidade -->
  <section class="mb-4">
    <div class="row g-3">
      <div class="col-12 col-md-6">
        <div class="card border-0 rounded-4 shadow-sm p-3 h-100 d-flex flex-row align-items-center gap-3">
          <div class="dashboard-card-icon rounded-circle d-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary" style="width: 48px; height: 48px; flex-shrink: 0;">
            <i class="fa-solid fa-piggy-bank fs-5"></i>
          </div>
          <div>
            <div class="small text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Taxa de Poupança <span class="fw-normal text-muted" style="font-size: 0.6rem; text-transform: none;">(Sobras / Receitas)</span></div>
            <div class="h5 mb-0 fw-bold <%= @savings_rate > 0 ? 'text-success' : 'text-danger' %>">
              <%= number_to_percentage(@savings_rate, precision: 1) %>
            </div>
          </div>
        </div>
      </div>
      <div class="col-12 col-md-6">
        <div class="card border-0 rounded-4 shadow-sm p-3 h-100 d-flex flex-row align-items-center gap-3">
          <div class="dashboard-card-icon rounded-circle d-flex align-items-center justify-content-center bg-info bg-opacity-10 text-info" style="width: 48px; height: 48px; flex-shrink: 0;">
            <i class="fa-solid fa-percent fs-5"></i>
          </div>
          <div>
            <div class="small text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Rentabilidade Histórica <span class="fw-normal text-muted" style="font-size: 0.6rem; text-transform: none;">(Lucro / Custo)</span></div>
            <div class="h5 mb-0 fw-bold <%= @portfolio_yield_pct >= 0 ? 'text-success' : 'text-danger' %>">
              <%= @portfolio_yield_pct >= 0 ? '+' : '' %><%= number_to_percentage(@portfolio_yield_pct, precision: 2) %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section Container (Identical to Dashboard Chart containers) -->
  <section class="mb-4">
    <div class="card rounded-4 shadow-sm p-4 overflow-hidden border-0">
      <h2 class="h5 fw-bold mb-4">Performance por Categoria</h2>
      
      <div class="category-groups">
        <% @investments_by_type.each do |type, investments| %>
          <% 
             category_invested = investments.sum(&:value)
             category_current = investments.sum(&:current_value)
             category_yield = category_current - category_invested
             id = type.parameterize
          %>
          <div class="mb-4 last-child-mb-0">
            <!-- Premium Accordion Header -->
            <button type="button" class="category-header-card collapsed text-start d-flex justify-content-between align-items-center p-3 mb-3 rounded-4 border transition-all hover-shadow-sm w-100" 
                 style="cursor: pointer; user-select: none; background-color: var(--theme-bg-card);"
                 data-bs-toggle="collapse" data-bs-target="#collapse-<%= id %>"
                 aria-expanded="false" aria-controls="collapse-<%= id %>">
              
              <div class="d-flex align-items-center gap-3 overflow-hidden">
                <div class="dashboard-card-icon rounded-circle d-flex align-items-center justify-content-center bg-success bg-opacity-10 text-success" style="width: 48px; height: 48px; flex-shrink: 0;">
                  <i class="fa-solid fa-layer-group fs-5"></i>
                </div>
                <div class="text-truncate">
                  <h6 class="mb-1 fw-bold text-highlight-theme text-uppercase text-truncate" style="letter-spacing: 0.5px;"><%= type %></h6>
                  <span class="badge bg-success bg-opacity-10 text-success border-0 small"><%= investments.count %> <%= investments.count == 1 ? 'aporte' : 'aportes' %></span>
                </div>
              </div>
              
              <div class="d-flex align-items-center gap-3 flex-shrink-0 ms-2">
                <div class="text-end d-none d-sm-block">
                  <span class="small text-muted d-block text-uppercase fw-bold" style="font-size: 0.65rem; letter-spacing: 0.5px;">Acumulado</span>
                </div>
                <div class="text-end">
                   <span class="fw-bold text-success fs-5 d-block"><%= number_to_currency(category_current, unit: "R$ ") %></span>
                </div>
                <div class="chevron-wrapper text-muted d-flex align-items-center justify-content-center bg-secondary bg-opacity-10 rounded-circle" style="width: 32px; height: 32px; transition: transform 0.3s ease;">
                  <i class="fa-solid fa-chevron-down small"></i>
                </div>
              </div>
            </button>

            <!-- List of items (Matching list-item-card style but cleaner) -->
            <div id="collapse-<%= id %>" class="collapse">
              <div class="row g-3 px-2 mb-4">
                <% investments.each do |inv| %>
                  <div class="col-12 col-md-6 col-xl-4">
                    <div class="card rounded-4 border p-3 h-100 shadow-none hover-shadow-sm transition-all" style="background-color: var(--theme-bg-sidebar-alt);">
                      <div class="d-flex justify-content-between mb-2">
                        <span class="small text-muted text-uppercase"><%= l(inv.date, format: "%B %Y") %></span>
                        <span class="badge bg-success bg-opacity-10 text-success border-0"><%= number_to_percentage(inv.interest_rate, precision: 1) %></span>
                      </div>
                      <div class="mb-2">
                        <div class="small text-muted">Aporte: <%= number_to_currency(inv.value, unit: "R$ ") %></div>
                        <div class="fw-bold fs-5 text-highlight-theme"><%= number_to_currency(inv.current_value, unit: "R$ ") %></div>
                      </div>
                      <div class="pt-2 border-top mt-auto">
                        <span class="small text-success fw-bold">+ <%= number_to_currency(inv.accumulated_yield, unit: "R$ ") %> de rendimento</span>
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <% if @investments_by_type.none? %>
        <div class="text-center py-5">
          <p class="text-muted mb-0">Nenhum investimento para analisar rendimentos.</p>
        </div>
      <% end %>
    </div>
  </section>

  <div class="p-3 rounded-4 d-flex align-items-center gap-3 border-0 small text-muted shadow-none mb-4" style="background-color: var(--theme-bg-card);">
    <i class="fa-solid fa-circle-info text-success"></i>
    <span>Estilo padronizado com o Dashboard principal. Os rendimentos utilizam capitalização composta diária (juros sobre juros calculados dia a dia).</span>
  </div>
</div>

<style>
  .letter-spacing-1 { letter-spacing: 0.5px; }
  .last-child-mb-0:last-child { margin-bottom: 0 !important; }
  .transition-all { transition: all 0.2s ease; }
  .hover-shadow-sm:hover { box-shadow: 0 4px 12px var(--theme-shadow); transform: translateY(-2px); }
  
  .category-header-card:hover, .category-header-card:not(.collapsed) {
    border-color: var(--theme-success) !important;
  }
  .category-header-card:not(.collapsed) .chevron-wrapper {
    transform: rotate(180deg);
    background-color: var(--theme-success) !important;
    color: #fff !important;
  }
  .category-header-card:not(.collapsed) .chevron-wrapper i {
    color: #fff !important;
  }
</style>
