<!DOCTYPE html>
<html>

  <head>
    <title>Money Tracker - Mtracker</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="turbo-cache-control" content="no-cache">
    <meta id="theme-color-meta" name="theme-color" content="#ffffff">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="dashboard-layout" data-controller="theme sidebar">
    <div class="dashboard-mobile-header d-md-none">
      <button type="button" class="dashboard-mobile-menu-btn" id="sidebar-toggle-btn" aria-expanded="false" aria-controls="dashboard-sidebar" aria-label="Abrir menu" data-sidebar-target="toggleButton" data-action="click->sidebar#toggle">
        <i class="fa-solid fa-bars" aria-hidden="true"></i>
      </button>
      <span class="dashboard-mobile-brand">Money Tracker</span>
      <span style="width: 44px;"></span>
    </div>
    <div class="dashboard-overlay d-md-none" data-sidebar-target="overlay" data-action="click->sidebar#close" aria-hidden="true"></div>
    <div class="dashboard-layout-shell">
      <aside id="dashboard-sidebar" class="dashboard-sidebar" data-sidebar-target="sidebar" aria-label="Navegação">
        <div class="sidebar-brand">
          <i class="fa-solid fa-chart-pie sidebar-brand-icon text-success" aria-hidden="true"></i>
          <span class="sidebar-brand-text fw-bold">MTracker</span>
        </div>
        <p class="sidebar-email text-muted small"><%= current_user&.email %></p>

        <nav class="sidebar-nav" aria-label="Menu principal">
          <% dash_active = current_page?(dashboard_path) %>
          <%= link_to dashboard_path, { class: "sidebar-link stagger-reveal #{'active' if dash_active}", title: "Dashboard", "data-reveal-delay" => "1" }.merge(dash_active ? { "aria-current" => "page" } : {}) do %>
            <i class="fa-solid fa-gauge-high" aria-hidden="true"></i>
            <span class="sidebar-link-text">Dashboard</span>
          <% end %>
          <% exp_active = request.path.start_with?(expenses_path) %>
          <%= link_to expenses_path, { class: "sidebar-link stagger-reveal #{'active' if exp_active}", title: "Gastos", "data-reveal-delay" => "2" }.merge(exp_active ? { "aria-current" => "page" } : {}) do %>
            <i class="fa-solid fa-wallet" aria-hidden="true"></i>
            <span class="sidebar-link-text">Gastos</span>
          <% end %>
          <% inc_active = request.path.start_with?(incomes_path) %>
          <%= link_to incomes_path, { class: "sidebar-link stagger-reveal #{'active' if inc_active}", title: "Salário", "data-reveal-delay" => "3" }.merge(inc_active ? { "aria-current" => "page" } : {}) do %>
            <i class="fa-solid fa-hand-holding-dollar" aria-hidden="true"></i>
            <span class="sidebar-link-text">Salário</span>
          <% end %>
          <% inv_active = request.path.start_with?(investments_path) && !request.path.include?("returns") %>
          <%= link_to investments_path, { class: "sidebar-link stagger-reveal #{'active' if inv_active}", title: "Investimentos", "data-reveal-delay" => "4" }.merge(inv_active ? { "aria-current" => "page" } : {}) do %>
            <i class="fa-solid fa-piggy-bank" aria-hidden="true"></i>
            <span class="sidebar-link-text">Investimentos</span>
          <% end %>
          <% ret_active = request.path.include?("returns") %>
          <%= link_to returns_investments_path, { class: "sidebar-link stagger-reveal #{'active' if ret_active}", title: "Rendimentos", "data-reveal-delay" => "5" }.merge(ret_active ? { "aria-current" => "page" } : {}) do %>
            <i class="fa-solid fa-arrow-trend-up" aria-hidden="true"></i>
            <span class="sidebar-link-text">Meus Rendimentos</span>
          <% end %>
        </nav>

        <div class="sidebar-footer">
          <%= link_to settings_path, class: "sidebar-icon", title: "Configurações", "aria-label" => "Configurações" do %>
            <i class="fa-solid fa-gear" aria-hidden="true"></i>
          <% end %>
          <button type="button" class="sidebar-icon border-0 bg-transparent p-0" title="Alternar tema (claro/escuro)" data-action="click->theme#toggle" aria-label="Alternar tema">
            <i class="fa-solid fa-toggle-off" data-theme-target="sidebarIcon" aria-hidden="true"></i>
          </button>
          <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "sidebar-icon", title: "Sair", "aria-label" => "Sair" do %>
            <i class="fa-solid fa-power-off" aria-hidden="true"></i>
          <% end %>
        </div>
      </aside>

      <main class="dashboard-main">
        <%= yield %>
      </main>
    </div>
    
    <% if user_signed_in? %>
      <%= render "shared/chat_widget" %>
    <% end %>

  </body>
</html>
