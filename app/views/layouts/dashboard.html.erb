<!DOCTYPE html>
<html>

  <head>
    <title>Money Tracker - Mtracker</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="dashboard-layout" data-controller="theme">

    <div class="container-fluid g-0 min-vh-100">
      <div class="row g-0 min-vh-100">
        <aside class="dashboard-sidebar col-md-3 col-lg-2">
          <div class="sidebar-brand">
            <i class="fa-solid fa-envelope me-2"></i>
            <span>Money Tracker</span>
          </div>
          <p class="sidebar-email text-muted small"><%= current_user&.email %></p>

          <nav class="sidebar-nav">
            <%= link_to dashboard_path, class: "sidebar-link #{'active' if request.path == dashboard_path}" do %>
              <i class="fa-solid fa-chart-line me-2"></i>
              Dashboard
            <% end %>
            <%= link_to expenses_path, class: "sidebar-link #{'active' if request.path.start_with?(expenses_path)}" do %>
              <i class="fa-solid fa-chart-line me-2"></i>
              Gastos
            <% end %>
            <%= link_to incomes_path, class: "sidebar-link #{'active' if request.path.start_with?(incomes_path)}" do %>
              <i class="fa-solid fa-dollar-sign me-2"></i>
              Salário
            <% end %>
            <%= link_to investments_path, class: "sidebar-link #{'active' if request.path.start_with?(investments_path)}" do %>
              <i class="fa-solid fa-chart-line me-2"></i>
              Investimentos
            <% end %>
          </nav>

          <div class="sidebar-footer">
            <%= link_to settings_path, class: "sidebar-icon", title: "Configurações" do %>
              <i class="fa-solid fa-gear"></i>
            <% end %>
            <button type="button" class="sidebar-icon border-0 bg-transparent p-0" title="Alternar tema (claro/escuro)" data-action="click->theme#toggle" aria-label="Alternar tema">
              <i class="fa-solid fa-toggle-off" data-theme-target="sidebarIcon"></i>
            </button>
            <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "sidebar-icon", title: "Sair" do %>
              <i class="fa-solid fa-power-off"></i>
            <% end %>
          </div>
        </aside>

        <main class="dashboard-main col-md-9 col-lg-10">
          <%= yield %>
        </main>
      </div>
    </div>

  </body>
</html>
