<%= simple_form_for(@income) do |f| %>
  <%= f.input :date, as: :string, label: "Data", input_html: { type: "date" } %>
  <%= f.input :value, label: "Valor (R$)", input_html: { step: "0.01", min: "0" } %>
  <%= f.input :income_type, label: "Categoria", input_html: { list: "income-types-datalist", placeholder: "Digite ou escolha uma categoria existente" } %>
  <datalist id="income-types-datalist">
    <% (@existing_income_types || []).each do |type| %>
      <option value="<%= type %>">
    <% end %>
  </datalist>
  <%= f.input :description, label: "Descrição", input_html: { rows: 2 } %>
  <%= f.button :submit, @income.persisted? ? "Atualizar ganho" : "Cadastrar ganho", class: "btn-primary" %>
  <%= link_to "Cancelar", incomes_path, class: "btn btn-outline-secondary ms-2", data: { turbo_frame: "_top", turbo: false } %>
<% end %>
