<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Ganhos / Salários</h1>
    <%= link_to "Novo ganho", new_income_path, class: "btn btn-primary" %>
  </div>

  <table class="table">
    <thead>
      <tr>
        <th>Data</th>
        <th>Descrição</th>
        <th>Categoria</th>
        <th>Valor (R$)</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @incomes.each do |income| %>
        <tr>
          <td><%= income.date %></td>
          <td><%= income.description %></td>
          <td><%= income.income_type %></td>
          <td><%= income.value %></td>
          <td>
            <%= link_to "Editar", edit_income_path(income), class: "btn btn-sm btn-outline-secondary" %>
            <%= link_to "Excluir", income_path(income), class: "btn btn-sm btn-outline-danger",
                data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
