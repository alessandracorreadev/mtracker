<div class="dashboard-page">
  <header class="dashboard-header d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <div>
      <h1 class="dashboard-title">Ganhos / Salários</h1>
      <p class="dashboard-subtitle text-muted mb-0">Lista de receitas por mês</p>
    </div>
    <%= link_to new_income_path, class: "btn btn-primary" do %>
      <i class="fa-solid fa-plus me-1"></i> Novo ganho
    <% end %>
  </header>

  <% if @incomes.any? %>
    <% @incomes_by_month.each do |month, incomes| %>
      <% total = incomes.sum(&:value) %>
      <div class="card rounded-3 shadow-sm overflow-hidden mb-4">
        <div class="card-header bg-transparent d-flex flex-wrap justify-content-between align-items-center gap-2 py-3">
          <h2 class="h5 mb-0 fw-bold"><%= l(month, format: :month_year) %></h2>
          <span class="badge bg-secondary fs-6"><%= number_to_currency(total, unit: "R$ ", separator: ",", delimiter: ".") %></span>
        </div>
        <div class="list-cards-wrapper">
          <% incomes.each do |income| %>
            <div class="list-item-card">
              <div class="list-item-card-body">
                <div class="list-item-card-row">
                  <span class="list-item-card-label">Data</span>
                  <span><%= income.date.strftime("%d/%m/%Y") %></span>
                </div>
                <div class="list-item-card-row">
                  <span class="list-item-card-label">Descrição</span>
                  <span><%= income.description.presence || "—" %></span>
                </div>
                <div class="list-item-card-row">
                  <span class="list-item-card-label">Categoria</span>
                  <span><%= income.income_type.presence || "—" %></span>
                </div>
                <div class="list-item-card-row list-item-card-value">
                  <span class="list-item-card-label">Valor</span>
                  <span class="fw-semibold"><%= number_to_currency(income.value, unit: "R$ ", separator: ",", delimiter: ".") %></span>
                </div>
                <div class="list-item-card-actions">
                  <%= link_to edit_income_path(income), class: "btn btn-outline-secondary list-item-card-btn", title: "Editar" do %>
                    <i class="fa-solid fa-pen"></i>
                  <% end %>
                  <%= link_to income_path(income), class: "btn btn-outline-danger list-item-card-btn", title: "Excluir",
                      data: { turbo_method: :delete, turbo_confirm: "Tem certeza que deseja excluir este ganho?" } do %>
                    <i class="fa-solid fa-trash"></i>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="card rounded-3 shadow-sm">
      <div class="card-body text-center py-5">
        <div class="text-muted mb-3">
          <i class="fa-solid fa-dollar-sign fa-3x"></i>
        </div>
        <p class="text-muted mb-3">Nenhum ganho cadastrado.</p>
        <%= link_to "Cadastrar primeiro ganho", new_income_path, class: "btn btn-primary" %>
      </div>
    </div>
  <% end %>
</div>
