<section class="auth-page py-5">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-12 col-md-9 col-lg-7 col-xl-5">
        <div class="card auth-card border-0 rounded-4 shadow-sm">
          <div class="card-body p-4 p-md-5">
            <h1 class="h4 fw-bold text-success mb-1">Entrar</h1>
            <p class="text-muted mb-4">Acesse sua conta para continuar acompanhando suas finanças.</p>

            <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "auth-form" }) do |f| %>
              <div class="form-inputs">
                <%= f.input :email,
                            required: false,
                            autofocus: true,
                            input_html: { autocomplete: "email" } %>
                <%= f.input :password,
                            required: false,
                            input_html: { autocomplete: "current-password" } %>
                <%= f.input :remember_me, as: :boolean if devise_mapping.rememberable? %>
              </div>

              <div class="form-actions mt-4">
                <%= f.button :submit, "Entrar", class: "btn btn-success rounded-pill w-100" %>
              </div>
            <% end %>

            <%= render "devise/shared/links" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
