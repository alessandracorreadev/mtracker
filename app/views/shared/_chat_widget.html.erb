<style>
.chat-widget-btn {
  transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1), box-shadow 0.3s ease;
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
}
.chat-widget-btn:hover {
  transform: scale(1.08) translateY(-2px);
  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
}

/* Container always in the DOM — controlled purely by JS class, no Bootstrap collapse */
.chat-widget-container {
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
  border: 1px solid var(--theme-border);
  transform-origin: bottom right;
  /* Hidden by default */
  opacity: 0;
  transform: scale(0.9) translateY(16px);
  pointer-events: none;
  transition: opacity 0.28s ease, transform 0.28s cubic-bezier(0.175, 0.885, 0.32, 1.15);
}
.chat-widget-container.chat-open {
  opacity: 1;
  transform: scale(1) translateY(0);
  pointer-events: auto;
}
[data-theme="dark"] .chat-widget-container {
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.6);
  border: 1px solid rgba(255,255,255,0.05);
}
</style>

<div id="ai-chat-widget" style="position: fixed; bottom: 25px; right: 25px; z-index: 1050; display: flex; flex-direction: column; align-items: flex-end;">
  <div class="mb-3 chat-widget-container" id="chatContainer" style="width: 380px; border-radius: 1rem; overflow: hidden; background-color: var(--theme-bg-page);">
    <div style="height: 550px; background-color: var(--theme-bg-page);">
      <turbo-frame id="chat_widget_frame" src="<%= chats_path %>">
        <div class="d-flex flex-column justify-content-center align-items-center h-100" style="color: var(--theme-text-muted);">
          <div class="spinner-border mb-3" style="width: 2rem; height: 2rem; color: var(--theme-accent);" role="status"></div>
          <p class="fw-medium">Conectando à IA...</p>
        </div>
      </turbo-frame>
    </div>
  </div>

  <button class="btn chat-widget-btn d-flex align-items-center justify-content-center"
          id="chat-fab-btn"
          type="button"
          aria-expanded="false"
          aria-controls="chatContainer"
          style="width: 65px; height: 65px; background-color: var(--theme-accent); border: none; outline: none; z-index: 1051; padding: 0; border-radius: 50%;">
    <i class="fa-solid fa-comments fa-2x text-white" id="chat-fab-icon" style="transition: transform 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275), opacity 0.15s ease;"></i>
  </button>
</div>

<script>
  (function() {
    var btn = document.getElementById('chat-fab-btn');
    var container = document.getElementById('chatContainer');
    var fabIcon = document.getElementById('chat-fab-icon');
    var isOpen = false;

    if (!btn || !container) return;

    function swapIcon(from, to) {
      fabIcon.style.transform = 'scale(0)';
      fabIcon.style.opacity = '0';
      setTimeout(function() {
        fabIcon.classList.remove(from);
        fabIcon.classList.add(to);
        fabIcon.style.transform = 'scale(1)';
        fabIcon.style.opacity = '1';
      }, 150);
    }

    btn.addEventListener('click', function() {
      isOpen = !isOpen;
      btn.setAttribute('aria-expanded', isOpen);

      if (isOpen) {
        container.classList.add('chat-open');
        swapIcon('fa-comments', 'fa-chevron-down');
      } else {
        container.classList.remove('chat-open');
        swapIcon('fa-chevron-down', 'fa-comments');
      }
    });

    // Allow the X button inside the chat header to close the widget too
    document.addEventListener('click', function(e) {
      if (e.target.closest && e.target.closest('[data-close-chat]') && isOpen) {
        isOpen = false;
        btn.setAttribute('aria-expanded', 'false');
        container.classList.remove('chat-open');
        swapIcon('fa-chevron-down', 'fa-comments');
      }
    });
  })();
</script>
